# ═══════════════════════════════════════════════════════
# Bubu & Dudu Crochet — Variables de entorno
# Copia este archivo como .env.local y llena los valores
# ═══════════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────────
# Tu connection string de MongoDB Atlas
# Obtenlo de: MongoDB Atlas > Database > Connect > Drivers
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/bubuyduducrochet?retryWrites=true&w=majority

# ── NextAuth ───────────────────────────────────────────
# Secret para firmar tokens JWT
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=tu-secret-aqui

# URL base de tu app (sin slash final)
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────
# COMO CONFIGURAR LOGIN CON GOOGLE:
#
# 1. Ve a https://console.cloud.google.com
# 2. Crea un proyecto nuevo
# 3. Ve a "APIs & Services" > "OAuth consent screen"
#    - User Type: External
#    - App name: Bubu y Dudu Crochet
#    - Support email: romanherrera548@gmail.com
#    - Authorized domains: tu-dominio.vercel.app
#    - Publica la app
#
# 4. Ve a "Credentials" > "Create Credentials" > "OAuth 2.0 Client ID"
#    - Type: Web application
#    - Authorized JavaScript origins:
#      http://localhost:3000
#      https://tu-dominio.vercel.app
#    - Authorized redirect URIs:
#      http://localhost:3000/api/auth/callback/google
#      https://tu-dominio.vercel.app/api/auth/callback/google
#
# 5. Copia Client ID y Client Secret:
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── Admin ──────────────────────────────────────────────
# Este email obtiene rol admin automaticamente al iniciar sesion
ADMIN_EMAIL=romanherrera548@gmail.com
