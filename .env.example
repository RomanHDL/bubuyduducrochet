# ═══════════════════════════════════════════════════════
# Bubu & Dudu Crochet — Variables de entorno
# Copia este archivo como .env.local y llena los valores
# ═══════════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────────
# Formato: mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/NOMBRE_BD
# Obtenlo de: MongoDB Atlas > Database > Connect > Drivers
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/bubuydudu?retryWrites=true&w=majority

# ── NextAuth ───────────────────────────────────────────
# Secret: string aleatorio para firmar tokens JWT
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=tu-secret-aqui

# URL base de tu app (sin slash final)
# Local: http://localhost:3000
# Produccion: https://tu-dominio.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────
# Obtenlo de: Google Cloud Console > APIs & Services > Credentials
# Tipo: OAuth 2.0 Client ID (Web Application)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-client-secret

# ── Admin ──────────────────────────────────────────────
# Email del administrador principal del sistema
ADMIN_EMAIL=romanherrera548@gmail.com
